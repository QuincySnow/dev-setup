# =============================================================================
# Git Ignore for dev-setup
# =============================================================================

# -----------------------------------------------------------------------------
# OS files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Backup files
# -----------------------------------------------------------------------------
*.bak
*.backup
*.old
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local

# -----------------------------------------------------------------------------
# Editor
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.sublime-*
.project
.classpath
.settings/

# -----------------------------------------------------------------------------
# Temporary files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp

# -----------------------------------------------------------------------------
# Build outputs
# -----------------------------------------------------------------------------
dist/
build/
out/

# -----------------------------------------------------------------------------
# Test coverage & E2E logs
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
tests/.e2e-logs/

# -----------------------------------------------------------------------------
# Vim
# -----------------------------------------------------------------------------
[._]*.s[a-v][a-z]
!/.gitignore
!*.svg
![/\_]*.s[a-z][a-z]
*.un~
Session.vim
.netrwhist
